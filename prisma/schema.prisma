generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  phoneNumber String?
  role        String    @default("member") // admin, secretary, trainer, member
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  memberProfile    MemberProfile? @relation("MemberProfile")
  staffProfile     StaffProfile?
  attendance       Attendance[]
  memberNotes      ProgressNote[] @relation("MemberNotes")
  trainerNotes     ProgressNote[] @relation("TrainerNotes")
  payments         Payment[]      @relation("UserPayments") // Fixed: relation name matches Payment.user
  approvedPayments Payment[]      @relation("PaymentApprovals") // Fixed: relation name matches Payment.approvedBy

  sessions Session[]

  @@index([email])
  @@index([role])
  // Composite index to speed up member/admin listings filtered by role and soft-delete flag
  @@index([role, deletedAt, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model MemberProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("MemberProfile", fields: [userId], references: [id], onDelete: Cascade)

  membershipId String
  membership   MembershipPackage @relation(fields: [membershipId], references: [id])

  joinDate   DateTime @default(now())
  expiryDate DateTime

  birthday            DateTime?
  gender              String?
  hearAboutUs         String?
  fitnessGoals        String?
  fitnessGoalsDetails String?
  paymentMethod       String?
  fingerprint         String?
  profileImage        String?
  emergencyContact    String?
  emergencyPhone      String?
  qrCode              String? @unique

  verified      Boolean @default(false)
  paymentStatus String  @default("pending") // pending, approved, rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([membershipId])
  @@index([expiryDate])
  @@index([verified])
  @@index([paymentStatus])
  // Useful for recent-member reports and dashboard queries
  @@index([createdAt])
}

model StaffProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String?
  joinDate       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model MembershipPackage {
  id          String   @id @default(cuid())
  name        String   @unique
  duration    Int
  price       Float
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members MemberProfile[]

  @@index([name])
}

model Attendance {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkInTime  DateTime
  checkOutTime DateTime?
  method       String    @default("qr")
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([checkInTime])
  // Helps time-based attendance queries (e.g. charts over ranges)
  @@index([createdAt])
}

model ProgressNote {
  id        String   @id @default(cuid())
  memberId  String
  member    User     @relation("MemberNotes", fields: [memberId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   User     @relation("TrainerNotes", fields: [trainerId], references: [id], onDelete: Cascade)
  note      String
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([trainerId])
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)

  amount        Float
  status        String  @default("pending") // pending, approved, rejected
  paymentMethod String
  reference     String? @unique
  description   String?

  // Who approved THIS specific payment
  approvedById String?
  approvedBy   User?     @relation("PaymentApprovals", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([approvedById])
  // Speeds up time-range revenue calculations
  @@index([createdAt])
  // Common filter pattern: approved payments by recency
  @@index([status, createdAt])
}
