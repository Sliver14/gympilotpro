generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Gym {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  email             String?
  phone             String?
  address           String?
  logo              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  heroSubtitle      String?
  heroTitle         String?
  primaryColor      String?             @default("#daa857")
  secondaryColor    String?             @default("#000000")
  status            String              @default("pending")
  customDomain      String?             @unique
  domainVerified    Boolean             @default(false)
  qrCodeUrl         String?
  coverImage        String?
  favicon           String?
  heroVideo         String?
  showcaseImage1    String?
  showcaseImage2    String?
  tagline           String?
  paystackPublicKey String?
  paystackSecretKey String?
  bankName           String?
  accountNumber      String?
  accountName        String?
  attendances       Attendance[]
  devices           Device[]
  subscriptions     GymSubscription[]
  memberProfiles    MemberProfile[]
  packages          MembershipPackage[]
  payments          Payment[]
  progressNotes     ProgressNote[]
  staffProfiles     StaffProfile[]
  users             User[]
}

model Device {
  id          String       @id @default(cuid())
  gymId       String
  name        String
  type        String
  location    String?
  createdAt   DateTime     @default(now())
  attendances Attendance[]
  gym         Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model GymSubscription {
  id        String   @id @default(cuid())
  gymId     String
  plan      String
  status    String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  firstName        String
  lastName         String
  phoneNumber      String?
  role             String         @default("member")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  profileImage     String?
  gymId            String
  status           String         @default("inactive")
  attendance       Attendance[]
  memberProfile    MemberProfile? @relation("MemberProfile")
  approvedPayments Payment[]      @relation("PaymentApprovals")
  payments         Payment[]      @relation("UserPayments")
  memberNotes      ProgressNote[] @relation("MemberNotes")
  trainerNotes     ProgressNote[] @relation("TrainerNotes")
  sessions         Session[]
  staffProfile     StaffProfile?
  gym              Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([role])
  @@index([role, deletedAt, createdAt])
  @@index([gymId])
  @@index([gymId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model MemberProfile {
  id                  String            @id @default(cuid())
  userId              String            @unique
  membershipId        String
  joinDate            DateTime          @default(now())
  expiryDate          DateTime
  gender              String?
  hearAboutUs         String?
  fitnessGoals        String?
  fitnessGoalsDetails String?
  paymentMethod       String?
  fingerprint         String?
  emergencyContact    String?
  emergencyPhone      String?
  qrCode              String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  paymentStatus       String            @default("pending")
  verified            Boolean           @default(false)
  birthday            String?
  gymId               String
  gym                 Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  membership          MembershipPackage @relation(fields: [membershipId], references: [id])
  user                User              @relation("MemberProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([membershipId])
  @@index([expiryDate])
  @@index([verified])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([gymId])
}

model StaffProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialization String?
  joinDate       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gymId          String
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gymId])
}

model MembershipPackage {
  id          String          @id @default(cuid())
  name        String          @unique
  duration    Int
  price       Float
  description String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  gymId       String
  members     MemberProfile[]
  gym         Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([gymId])
}

model Attendance {
  id           String    @id @default(cuid())
  userId       String
  checkInTime  DateTime
  checkOutTime DateTime?
  method       String    @default("qr")
  createdAt    DateTime  @default(now())
  deviceId     String?
  gymId        String
  device       Device?   @relation(fields: [deviceId], references: [id])
  gym          Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([checkInTime])
  @@index([createdAt])
  @@index([gymId])
  @@index([gymId, createdAt])
}

model ProgressNote {
  id        String   @id @default(cuid())
  memberId  String
  trainerId String
  note      String
  weight    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member    User     @relation("MemberNotes", fields: [memberId], references: [id], onDelete: Cascade)
  trainer   User     @relation("TrainerNotes", fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([trainerId])
  @@index([gymId])
}

model Payment {
  id            String    @id @default(cuid())
  userId        String
  amount        Float
  status        String    @default("pending")
  paymentMethod String
  reference     String?   @unique
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approvedAt    DateTime?
  approvedById  String?
  gymId         String
  approvedBy    User?     @relation("PaymentApprovals", fields: [approvedById], references: [id])
  gym           Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user          User      @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([approvedById])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([gymId])
  @@index([gymId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model SaaSPayment {
  id        String   @id @default(cuid())
  email     String
  amount    Float
  plan      String
  reference String   @unique
  status    String   @default("pending")
  createdAt DateTime @default(now())
  gymId     String?
  userId    String?

  @@index([email])
  @@index([reference])
}
